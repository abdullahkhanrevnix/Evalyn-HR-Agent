# ============================================================
# EVALYN — Environment Variables Template
# Copy this file to:
#   backend/.env      (for the FastAPI backend)
#   frontend/.env.local  (for the Next.js frontend)
# Fill in all values before running the project.
# ============================================================


# ── Database ─────────────────────────────────────────────────
DATABASE_URL=


# ── Application Security ──────────────────────────────────────
SECRET_KEY=


# ── AI / LLM ─────────────────────────────────────────────────
GROQ_API_KEY=


# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=
# Used by the frontend to reach the LangGraph / FastAPI server
NEXT_PUBLIC_LANGGRAPH_API_URL=


# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
RESEND_WEBHOOK_SECRET=
OPERATIONS_MANAGER_EMAIL=
HR_EMAIL=


# ── LinkedIn Integration ──────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=


# ── Indeed Integration ────────────────────────────────────────
INDEED_CLIENT_ID=
INDEED_CLIENT_SECRET=
INDEED_REDIRECT_URL=
